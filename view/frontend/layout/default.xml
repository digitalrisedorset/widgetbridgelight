<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <link src="https://widgets-cdn.reactedge.net" src_type="url" rel="preconnect" crossorigin="anonymous"/>
        <script src="ReactEdge_WidgetBridge::js/reactedge-loader.js"/>
    </head>
    <body>
        <referenceContainer name="head.additional">
            <block name="reactedge-runtime-config" template="ReactEdge_WidgetBridge::runtime-config.phtml" >
                <arguments>
                    <argument name="view_model"
                              xsi:type="object">ReactEdge\WidgetBridge\ViewModel\Widget</argument>
                </arguments>
            </block>
            <block class="ReactEdge\WidgetBridge\Block\Head"
                   name="reactedge.styles"
                   template="ReactEdge_WidgetBridge::head/assets.phtml"/>
        </referenceContainer>
    </body>
</page>
