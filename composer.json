{
    "name": "reactedge/widgetbridgelight",
    "description": "Bridge between Magento/Mage-OS and ReactEdge widgets.",
    "type": "magento2-module",
    "license": "MIT",

    "require": {
        "php": "^8.1",
        "magento/framework": "*"
    },

    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "ReactEdge\\WidgetBridge\\": ""
        }
    },

    "extra": {
        "map": [
            [
                "*",
                "ReactEdge/WidgetBridge"
            ]
        ]
    }
}
