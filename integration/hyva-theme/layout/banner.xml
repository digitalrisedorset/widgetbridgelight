<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block name="banner-widget"
                   class="ReactEdge\WidgetBridge\Block\Widget"
                   template="ReactEdge_WidgetBridge::banner.phtml"
                   ifconfig="reactedge/banner/enabled"
                   before="-"
            >

                <arguments>
                    <argument name="widget_id" xsi:type="string">banner</argument>
                    <argument name="view_model"
                              xsi:type="object">ReactEdge\WidgetBridge\ViewModel\Widget</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
