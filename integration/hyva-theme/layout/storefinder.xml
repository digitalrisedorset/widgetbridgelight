<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block name="magsite.storefinder"
                   class="ReactEdge\WidgetBridge\Block\Widget"
                   template="ReactEdge_WidgetBridge::storefinder.phtml"
                   ifconfig="reactedge/storefinder/enabled"
                    after="intentdiscovery-widget">

                <arguments>
                    <argument name="widget_id" xsi:type="string">storefinder</argument>
                    <argument name="view_model"
                              xsi:type="object">ReactEdge\WidgetBridge\ViewModel\Widget</argument>
                </arguments>

            </block>
        </referenceContainer>
    </body>
</page>
