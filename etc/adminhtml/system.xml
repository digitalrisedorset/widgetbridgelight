<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">

    <system>

        <section id="reactedge"
                 translate="label"
                 sortOrder="900"
                 showInDefault="1"
                 showInWebsite="1"
                 showInStore="1">

            <label>ReactEdge</label>
            <tab>general</tab>
            <resource>ReactEdge_Integration::config</resource>

            <!-- ===================== -->
            <!-- USP                   -->
            <!-- ===================== -->
            <group id="usp"
                   translate="label"
                   sortOrder="20"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="20">

                <label>USP Widget</label>

                <field id="enabled" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable USP</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- ===================== -->
            <!-- BANNER                -->
            <!-- ===================== -->
            <group id="banner"
                   translate="label"
                   sortOrder="30"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Banner Widget</label>

                <field id="enabled" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Banner</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- ===================== -->
            <!-- STORE FINDER          -->
            <!-- ===================== -->
            <group id="storefinder"
                   translate="label"
                   sortOrder="50"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Store Finder Widget</label>

                <field id="enabled" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Store Finder</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- ===================== -->
            <!-- MEGA MENU             -->
            <!-- ===================== -->
            <group id="megamenu"
                   translate="label"
                   sortOrder="60"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Mega Menu Widget</label>

                <field id="enabled" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Mega Menu</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- ===================== -->
            <!-- Minicart                   -->
            <!-- ===================== -->
            <group id="minicart"
                   translate="label"
                   sortOrder="70"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Minicart Widget</label>

                <field id="enabled" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Minicart</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- ===================== -->
            <!-- Google Reviews                   -->
            <!-- ===================== -->
            <group id="googlereviews"
                   translate="label"
                   sortOrder="80"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Google Reviews Widget</label>

                <field id="enabled" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Widget</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>


            <!-- ===================== -->
            <!-- PRODUCT GALLERY      -->
            <!-- ===================== -->
            <group id="productgallery"
                   translate="label"
                   sortOrder="100"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Product Gallery Widget</label>

                <field id="enabled" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Product Gallery</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- ===================== -->
            <!-- SUBRESOURCE INTEGRITY -->
            <!-- ===================== -->
            <group id="sri"
                   translate="label"
                   sortOrder="15"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Subresource Integrity</label>

                <field id="enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enable SRI</label>
                    <comment>Add integrity metadata when loading published ReactEdge assets.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- ===================== -->
            <!-- GOOGLE MAPS           -->
            <!-- ===================== -->
            <group id="google_maps"
                   translate="label"
                   sortOrder="40"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Google Maps</label>

                <field id="api_key"
                       translate="label comment"
                       type="obscure"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>API Key</label>
                    <comment>Google Maps API key used by ReactEdge widgets such as Store Finder.</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>

                <field id="place_id"
                       translate="label comment"
                       type="text"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Place ID</label>
                    <comment>Google Place ID used by widgets such as Google Reviews.</comment>
                </field>
            </group>

            <!-- ===================== -->
            <!-- WIDGET SSR            -->
            <!-- ===================== -->
            <group id="widgets_ssr"
                   translate="label"
                   sortOrder="90"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>Widget Server-Side Rendering</label>

                <field id="enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enable Widget SSR</label>
                    <comment>Use the ReactEdge SSR service when rendering supported widgets.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="base_url"
                       translate="label comment"
                       type="text"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>SSR Base URL</label>
                    <comment>Base URL of the ReactEdge SSR service (for example: http://localhost:4000).</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                    <validate>required-entry validate-url</validate>
                </field>
            </group>
        </section>

    </system>

</config>
